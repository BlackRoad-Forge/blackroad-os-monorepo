{
  "name": "@blackroad/desktop-app",
  "version": "1.0.0",
  "description": "BlackRoad Desktop - Native app for macOS, Windows, Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "clean": "rm -rf dist .next out build node_modules/.cache"
  },
  "build": {
    "appId": "io.blackroad.desktop",
    "productName": "BlackRoad",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "axios": "^1.6.5",
    "@blackroad/shared": "workspace:*"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
